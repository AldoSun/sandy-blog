{
  "site": {{ .Site.Title | jsonify }},
  "url":  {{ .Site.BaseURL | jsonify }},
  "generated": "{{ now.Format "2006-01-02T15:04:05Z07:00" }}",
  "count": {{ len .Site.RegularPages }},
  "articles": [
    {{- range $i, $p := .Site.RegularPages -}}
    {{- if $i }},{{ end }}
    {
      "title":   {{ $p.Title | jsonify }},
      "url":     {{ $p.Permalink | jsonify }},
      "date":    "{{ $p.Date.Format "2006-01-02" }}",
      "tags":    {{ with $p.Params.tags }}{{ . | jsonify }}{{ else }}[]{{ end }},
      "summary": {{ $p.Summary | jsonify }}
    }
    {{- end }}
  ]
}